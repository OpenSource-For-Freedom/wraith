<Window x:Class="WRAITH.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WRAITH - Update Available"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="Transparent">

  <Grid>
    <Border BorderBrush="#2A1A5A" BorderThickness="1" CornerRadius="8"
            Background="{StaticResource BrWindowBackground}">
      <Border.Effect>
        <DropShadowEffect Color="#4D2090" BlurRadius="30" ShadowDepth="0" Opacity="0.65"/>
      </Border.Effect>

      <StackPanel>

        <!-- Title bar / drag strip -->
        <Border Background="#05051A" CornerRadius="8,8,0,0"
                Height="34" MouseLeftButtonDown="TitleBar_MouseDown">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
            <Image Source="Assets/wraith.png" Width="15" Height="15"
                   VerticalAlignment="Center" Margin="0,0,7,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="WRAITH  ·  Update Available"
                       Foreground="#3E5568" FontSize="11"
                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
          </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Margin="32,24,32,28">

          <!-- Watermark logo -->
          <Grid>
            <Image Source="Assets/wraith.png" Opacity="0.04" Width="180"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <StackPanel>

              <!-- Heading -->
              <TextBlock Text="Update Available" FontSize="20" FontWeight="Bold"
                         FontFamily="Segoe UI" Margin="0,0,0,3">
                <TextBlock.Foreground>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#D4AF37" Offset="0"/>
                    <GradientStop Color="#E8F4FF" Offset="0.5"/>
                    <GradientStop Color="#D4AF37" Offset="1"/>
                  </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                  <DropShadowEffect Color="#D4AF37" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                </TextBlock.Effect>
              </TextBlock>

              <TextBlock x:Name="SubtitleBlock"
                         Text="A new version of WRAITH has been downloaded and is ready to install."
                         Foreground="#36495A" FontSize="10.5" FontFamily="Segoe UI"
                         TextWrapping="Wrap" Margin="0,0,0,20"/>

              <!-- Version diff panel -->
              <Border BorderBrush="#1C1C3C" BorderThickness="1" CornerRadius="5"
                      Background="#08081E" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="Current" Foreground="#415A6E" FontSize="11"
                             FontFamily="Segoe UI" Margin="0,0,0,7" VerticalAlignment="Center"/>
                  <TextBlock x:Name="CurrentVersionText" Grid.Column="1"
                             Foreground="#A8C8E8" FontSize="11" FontFamily="Segoe UI SemiBold"
                             Margin="0,0,0,7" VerticalAlignment="Center"/>

                  <TextBlock Grid.Row="1" Text="New version" Foreground="#415A6E" FontSize="11"
                             FontFamily="Segoe UI" VerticalAlignment="Center"/>
                  <TextBlock x:Name="NewVersionText" Grid.Row="1" Grid.Column="1"
                             Foreground="#D4AF37" FontSize="12" FontFamily="Segoe UI SemiBold"
                             VerticalAlignment="Center"/>
                </Grid>
              </Border>

              <!-- Release notes section -->
              <TextBlock Text="WHAT'S CHANGED" FontSize="9.5" FontWeight="SemiBold"
                         FontFamily="Segoe UI" Foreground="#2E4050"
                         Margin="0,0,0,6"/>

              <Border BorderBrush="#1C1C3C" BorderThickness="1" CornerRadius="5"
                      Background="#07071A" Margin="0,0,0,20" MaxHeight="200">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <TextBlock x:Name="ChangelogText"
                             Text="Loading release notes..."
                             Foreground="#7090A8" FontSize="11" FontFamily="Segoe UI"
                             TextWrapping="Wrap" Padding="14,12" LineHeight="18"/>
                </ScrollViewer>
              </Border>

              <!-- Divider -->
              <Border BorderBrush="#1A1A38" BorderThickness="0,1,0,0" Margin="0,0,0,18"/>

              <!-- Action buttons -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterBtn"
                        Content="Remind Me Later"
                        Width="Auto" MinWidth="130" Height="32" Margin="0,0,10,0" Padding="14,0"
                        Click="LaterBtn_Click"
                        Style="{StaticResource SpellButton}"
                        Foreground="#415A6E" FontSize="11.5"/>
                <Button x:Name="UpdateBtn"
                        Content="⚡  Restart &amp; Apply Update"
                        Width="Auto" MinWidth="195" Height="32" Padding="14,0"
                        Click="UpdateBtn_Click"
                        Style="{StaticResource WarningButton}"
                        FontSize="11.5"/>
              </StackPanel>

            </StackPanel>
          </Grid>

        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>

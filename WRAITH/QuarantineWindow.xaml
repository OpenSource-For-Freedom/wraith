<Window x:Class="WRAITH.QuarantineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WRAITH.Converters"
        Title="WRAITH Quarantine Vault"
        Height="520" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#0C0C20"
        Foreground="#E8F4FF">
    <Window.Resources>
        <conv:SeverityToBrushConverter x:Key="SeverityBrush"/>
        <conv:SeverityToForegroundConverter x:Key="SeverityFg"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A1A3A"/>
            <Setter Property="Foreground" Value="#E8F4FF"/>
            <Setter Property="BorderBrush" Value="#3A2A6A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1D1D40"/>
            <Setter Property="Foreground" Value="#F5D87A"/>
            <Setter Property="BorderBrush" Value="#3A2A6A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#E8F4FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2A1A5A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8F4FF"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E245A"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Quarantine Vault" FontSize="18" FontWeight="Bold" Foreground="#A8C8E8"/>
            <TextBlock Text="  |  Select one or more rows, then Restore/Delete." Margin="8,4,0,0" Foreground="#B8A040"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Padding="10,8"
                CornerRadius="4"
                BorderBrush="#3A2A6A"
                BorderThickness="1"
                Background="#121232"
                AllowDrop="True"
                DragOver="DropZone_DragOver"
                Drop="DropZone_Drop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Manual Import: drag files here from Explorer, or click Import Files. Use this for HIGH findings you want to quarantine manually."
                           Foreground="#C8D8E8"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Import Files..."
                        Width="130"
                        Margin="12,0,0,0"
                        Click="ImportFiles_Click"/>
            </Grid>
        </Border>

        <DataGrid x:Name="VaultGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#12122A"
                  RowBackground="#12122A"
                  AlternatingRowBackground="#0E0E22"
                  BorderBrush="#2A1A5A"
                  BorderThickness="1"
                  Foreground="#E8F4FF"
                  HorizontalGridLinesBrush="#2A1A5A"
                  VerticalGridLinesBrush="#2A1A5A">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Quarantined At (UTC)" Binding="{Binding QuarantinedAtUtc, StringFormat=u}" Width="180"/>
                <DataGridTemplateColumn Header="SEVERITY" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="4,2"
                                    Background="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Severity}" FontSize="11" FontWeight="Bold"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityFg}}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="280"/>
                <DataGridTextColumn Header="Vault File" Binding="{Binding QuarantinedPath}" Width="220"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="200"/>
                <DataGridTextColumn Header="SHA256" Binding="{Binding Sha256}" Width="200"/>
                <DataGridTextColumn Header="Deleted" Binding="{Binding Deleted}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Refresh" Width="100" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="Open Vault Folder" Width="140" Margin="0,0,8,0" Click="OpenFolder_Click"/>
            <Button Content="Restore Selected" Width="130" Margin="0,0,8,0" Click="Restore_Click"/>
            <Button Content="Delete Selected (Admin)" Width="170" Margin="0,0,8,0" Click="Delete_Click"/>
            <Button Content="Close" Width="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
